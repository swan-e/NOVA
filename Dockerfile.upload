# Baked image for Railway deployment.
# No volume mounts — everything is built into the image.
# receipts/ is ephemeral on Railway since files are deleted after Drive upload.

FROM node:20-slim

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

RUN npm prune --omit=dev

CMD ["node", "build/upload-server.js"]